{
  "name": "ccinit",
  "version": "1.0.0",
  "description": "Auto-generate Claude Code project configuration from your codebase",
  "type": "module",
  "bin": {
    "ccinit": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "claude",
    "claude-code",
    "ai",
    "mcp",
    "developer-tools",
    "cli",
    "scaffolding",
    "configuration"
  ],
  "author": "Zhiyuan Wang",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zzhiyuann/ccinit.git"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "chalk": "^5.4.1",
    "ora": "^8.2.0",
    "toml": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
